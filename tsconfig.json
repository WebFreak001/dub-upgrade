{
	"compilerOptions": {
		"target": "es2025",
		"module": "nodenext",
		"outDir": "lib",
		"rootDir": "src",
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strictBindCallApply": true,
		"strictPropertyInitialization": true,
		"esModuleInterop": true,
		"types": ["node"]
	},
	"exclude": ["node_modules"]
}